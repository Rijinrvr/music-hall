# Spotify API Credentials
# Get these from https://developer.spotify.com/dashboard
SPOTIPY_CLIENT_ID=your_client_id_here
SPOTIPY_CLIENT_SECRET=your_client_secret_here

# Redirect URI must match the one in your Spotify Developer Dashboard
# It should be: http://localhost:8000/api/spotify/callback/
SPOTIPY_REDIRECT_URI=http://localhost:8000/api/spotify/callback/
